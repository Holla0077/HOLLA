generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum TransactionStatus {
  PENDING
  COMPLETED
  FAILED
}

enum TransactionRail {
  HOLLA_INTERNAL
  GHANA
  BLOCKCHAIN
}

enum TransactionMethod {
  // GHANA
  MTN_MOMO
  TELECEL_MOMO
  AT_MONEY
  BANK_TRANSFER
  VISA_CARD

  // INTERNAL
  HOLLA_TO_HOLLA

  // BLOCKCHAIN
  BTC
  ETH
  USDT_ERC20
  USDC_ERC20
  LTC
  DASH
  BCH
}

enum LedgerEntryType {
  DEBIT
  CREDIT
}

enum VerificationStatus {
  NONE
  PENDING
  APPROVED
  REJECTED
}

model User {
  id           String   @id @default(cuid())
  username     String   @unique
  email        String   @unique
  phone        String   @unique
  passwordHash String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  fullName    String?
  gender      String?
  dateOfBirth DateTime?

  wallets      Wallet[]
  transactions Transaction[] @relation("UserTransactions")
  topupRequests    TopupRequest[]
  withdrawRequests WithdrawRequest[]

  isVerified         Boolean            @default(false)
  verifiedAt         DateTime?
  verificationStatus VerificationStatus @default(NONE)

  passwordResetTokens PasswordResetToken[]
  kycDocument         KycDocument?
  cryptoAddresses     CryptoAddress[]
}

model CryptoAddress {
  id        String   @id @default(cuid())
  userId    String
  coin      String   // "BTC" | "ETH" etc.
  address   String   @unique
  hdIndex   Int
  createdAt DateTime @default(now())

  user     User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  deposits CryptoDeposit[]

  @@unique([userId, coin])
  @@index([coin])
}

model CryptoDeposit {
  id            String   @id @default(cuid())
  addressId     String
  txid          String
  vout          Int
  amountSat     BigInt   @db.BigInt
  confirmations Int      @default(0)
  status        String   @default("PENDING") // PENDING | CONFIRMED | CREDITED
  walletId      String?
  txRecordId    String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  address CryptoAddress @relation(fields: [addressId], references: [id], onDelete: Cascade)

  @@unique([txid, vout])
  @@index([addressId])
}

model KycDocument {
  id         String             @id @default(cuid())
  userId     String             @unique
  frontPath  String
  backPath   String
  status     VerificationStatus @default(PENDING)
  adminNote  String?
  reviewedBy String?
  reviewedAt DateTime?
  createdAt  DateTime           @default(now())
  updatedAt  DateTime           @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model AdminAuditLog {
  id           String   @id @default(cuid())
  action       String
  targetUserId String?
  meta         Json?
  createdAt    DateTime @default(now())
}

enum AssetType {
  FIAT
  CRYPTO
}

model Asset {
  id   String    @id @default(cuid())
  code String    @unique // e.g. GHS, BTC, ETH, USDT-ERC20
  name String
  type AssetType

  wallets       Wallet[]
  feeRules      FeeRule[]
  transactions  Transaction[]
  ledgerEntries LedgerEntry[]
  feeCharges    FeeCharge[]
}

model Wallet {
  id     String @id @default(cuid())
  user   User   @relation(fields: [userId], references: [id])
  userId String

  asset   Asset  @relation(fields: [assetId], references: [id])
  assetId String

  // money in minor units (e.g. pesewas, satoshis)
  balance BigInt @default(0) @db.BigInt

  transactionsFrom Transaction[] @relation("FromWallet")
  transactionsTo   Transaction[] @relation("ToWallet")
  ledgerEntries    LedgerEntry[]
  topupRequests    TopupRequest[]
  withdrawRequests WithdrawRequest[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, assetId])
}

model TopupRequest {
  id          String   @id @default(cuid())
  userId      String
  walletId    String
  amount      BigInt   // store in pesewas (GHS * 100)
  phone       String
  network     String   // "MTN" | "TELECEL" | "AT"
  status      String   @default("PENDING") // PENDING | COMPLETED | FAILED | CANCELED
  externalRef String?  // MTN referenceId (UUID) sent to MoMo API
  providerStatus String? // raw status from MTN callback / poll: SUCCESSFUL | FAILED | PENDING
  failureReason  String? // reason text if failed
  transactionId  String? // linked Transaction record id
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user      User     @relation(fields: [userId], references: [id])
  wallet    Wallet   @relation(fields: [walletId], references: [id])
}

model WithdrawRequest {
  id          String   @id @default(cuid())
  userId      String
  walletId    String
  amount      BigInt   // pesewas
  phone       String
  network     String
  status      String   @default("PENDING") // PENDING | COMPLETED | FAILED
  externalRef String?  // MTN referenceId
  providerStatus String?
  failureReason  String?
  transactionId  String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user   User   @relation(fields: [userId], references: [id])
  wallet Wallet @relation(fields: [walletId], references: [id])
}

model Transaction {
  id     String @id @default(cuid())
  user   User   @relation("UserTransactions", fields: [userId], references: [id])
  userId String

  asset   Asset  @relation(fields: [assetId], references: [id])
  assetId String

  rail   TransactionRail
  method TransactionMethod
  status TransactionStatus @default(PENDING)

  // Internal HOLLA-to-HOLLA transfers will use fromWallet/toWallet
  fromWallet   Wallet? @relation("FromWallet", fields: [fromWalletId], references: [id])
  fromWalletId String?

  toWallet   Wallet? @relation("ToWallet", fields: [toWalletId], references: [id])
  toWalletId String?

  // positive amount in minor units
  amount BigInt @db.BigInt

  // total fee charged (minor units)
  feeTotal BigInt @default(0) @db.BigInt

  reference String? @unique
  metadata  Json?

  ledgerEntries LedgerEntry[]
  feeCharges    FeeCharge[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model LedgerEntry {
  id String @id @default(cuid())

  transaction   Transaction @relation(fields: [transactionId], references: [id])
  transactionId String

  wallet   Wallet? @relation(fields: [walletId], references: [id])
  walletId String?

  asset   Asset  @relation(fields: [assetId], references: [id])
  assetId String

  // DEBIT or CREDIT for bookkeeping
  entryType LedgerEntryType

  // signed amount in minor units; sum of all entries per asset per transaction must be 0
  amount BigInt @db.BigInt

  createdAt DateTime @default(now())
}

model FeeRule {
  id String @id @default(cuid())

  rail   TransactionRail
  method TransactionMethod

  asset   Asset?  @relation(fields: [assetId], references: [id])
  assetId String?

  // optional flat fee in minor units
  flatAmount BigInt? @db.BigInt

  // optional percentage in basis points (100 = 1%)
  percentageBps Int?

  isActive Boolean @default(true)

  feeCharges FeeCharge[]
}

model FeeCharge {
  id String @id @default(cuid())

  transaction   Transaction @relation(fields: [transactionId], references: [id])
  transactionId String

  feeRule   FeeRule? @relation(fields: [feeRuleId], references: [id])
  feeRuleId String?

  asset   Asset  @relation(fields: [assetId], references: [id])
  assetId String

  amount BigInt @db.BigInt

  createdAt DateTime @default(now())
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model SupportConversation {
  id     String                    @id @default(cuid())
  userId String
  status SupportConversationStatus @default(OPEN)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  messages SupportMessage[]

  @@index([userId])
}

model SupportMessage {
  id             String        @id @default(cuid())
  conversationId String
  sender         SupportSender
  body           String

  createdAt DateTime @default(now())

  conversation SupportConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId, createdAt])
}

enum SupportConversationStatus {
  OPEN
  CLOSED
}

enum SupportSender {
  USER
  AGENT
  SYSTEM
}
